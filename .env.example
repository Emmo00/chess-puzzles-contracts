# PayoutClaims deployment settings (Foundry)
# Use a funded deployer key on the selected Celo network.
PRIVATE_KEY=
PAYOUT_TOKEN=
SERVER_SIGNER=
CHECK_IN_AMOUNT=10000000000000000
MAX_DAILY_CHECK_INS=100
OWNER=

# Network settings
CELO_MAINNET_RPC_URL=https://forno.celo.org
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
CHAIN_ID=42220
# Set CHAIN_ID=11142220 for Celo Sepolia.

# Optional contract verification
CELOSCAN_API_KEY=

# Backend signing example settings (ethers)
CLAIMS_CONTRACT=
USER_ADDRESS=
# Keep signing key on backend only.
SERVER_PRIVATE_KEY=

# Optional signing payload overrides
NONCE=1
DAY=
DEADLINE=
AMOUNT=1000000000000000000
CLAIM_ID=
